  CUENTAS_POR_PAGAR // CxP (antes "PAGABLES")
  GARANTIA
  REPARACIONES
  COMPRAS
  LOGISTICA
  SISTEMA
  SEGURIDAD
  FACTURACION
  OTROS
}

enum NotiSeverity {
  INFORMACION
  EXITO
  ALERTA // (Si prefieres "ADVERTENCIA", cámbialo aquí y en UI)
  ERROR
  CRITICO
}

enum NotiAudience {
